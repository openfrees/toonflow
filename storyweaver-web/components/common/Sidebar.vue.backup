  color: #fff !important;
  background: var(--color-primary-gradient) !important;
}

.sidebar__item-icon {
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sidebar__item-label {
  font-size: 0.76rem;
  font-weight: 500;
  white-space: nowrap;
}

.sidebar__footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 12px 10px 4px;
  border-top: 1px solid var(--color-border);
}

.sidebar__footer-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  cursor: pointer;
}

.sidebar__footer-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.sidebar__footer-label {
  font-size: 0.6rem;
  color: var(--color-text-secondary);
}

.sidebar__footer-row {
  display: flex;
  gap: 12px;
}

.sidebar__footer-link {
  font-size: 0.65rem;
