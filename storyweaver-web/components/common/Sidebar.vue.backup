<template>
  <aside class="sidebar">
    <!-- Logo -->
    <div class="sidebar__logo">
      <span class="sidebar__logo-icon">✦</span>
      <span class="sidebar__logo-text">创剧AI</span>
    </div>

    <!-- 主导航（分组 + 分隔线） -->
    <nav class="sidebar__nav">
      <template v-for="(group, gi) in navGroups" :key="gi">
        <!-- 分组间分隔线 -->
        <div v-if="gi > 0" class="sidebar__divider"></div>
        <template v-for="item in group" :key="item.path">
          <!-- 不需要登录的页面：使用真实 <a> 标签，SEO 友好 -->
          <a
            v-if="!item.requireAuth"
            :href="item.path"
            class="sidebar__item"
            :class="{ 'sidebar__item--active': isActive(item.path) }"
          >
            <Icon :name="item.icon" class="sidebar__item-icon" size="22" />
            <span class="sidebar__item-label">{{ item.label }}</span>
          </a>
          <!-- 需要登录的页面：使用 <a> 标签 + 点击拦截 -->
          <a
            v-else
            href="javascript:;"
            class="sidebar__item"
            :class="{ 'sidebar__item--active': isActive(item.path) }"
            @click="handleAuthClick(item.path, $event)"
          >
            <Icon :name="item.icon" class="sidebar__item-icon" size="22" />
            <span class="sidebar__item-label">{{ item.label }}</span>
          </a>
        </template>
      </template>
    </nav>

    <!-- 底部操作 -->
    <div class="sidebar__footer">
      <div class="sidebar__footer-item">
        <Icon name="lucide:smartphone" class="sidebar__footer-icon" size="18" />
        <span class="sidebar__footer-label">关注小程序</span>
      </div>
      <div class="sidebar__footer-row">
        <span class="sidebar__footer-link">手册</span>
        <span class="sidebar__footer-link">客服</span>
      </div>
      <div class="sidebar__footer-row">
        <span class="sidebar__footer-link">定价</span>
        <span class="sidebar__footer-link">建议</span>
      </div>
    </div>
  </aside>
</template>

<script setup>
/**
 * 左侧导航栏组件
 */
import { useUserStore } from '~/stores/user'

const route = useRoute()
const userStore = useUserStore()

/* 导航分组：首页+作品 | 小说转剧本+写剧本+评剧本 | 我的 */
const navGroups = [
  [
    { icon: 'lucide:house', label: '首页', path: '/', requireAuth: false },
    { icon: 'lucide:folder-open', label: '作品', path: '/works', requireAuth: true },
    // { icon: 'lucide:megaphone', label: '快讯', path: '/news', requireAuth: false },
  ],
  [
    { icon: 'lucide:book-text', label: '小说转剧本', path: '/novel-to-script', requireAuth: true },
    { icon: 'lucide:pen-line', label: '写剧本', path: '/write', requireAuth: true },
    { icon: 'lucide:clipboard-check', label: '评剧本', path: '/review', requireAuth: true },
    // { icon: 'lucide:clapperboard', label: '拆短片', path: '/analyze', requireAuth: true },
    // { icon: 'lucide:video', label: '做短片', path: '/produce', requireAuth: true },
  ],
  [
    // { icon: 'lucide:image', label: '作图', path: '/design', requireAuth: true },
    { icon: 'lucide:user', label: '我的', path: '/user/profile', requireAuth: true },
  ],
]

const isActive = (path) => {
  if (path === '/') return route.path === '/'
  return route.path.startsWith(path)
}

/**
 * 处理需要登录的导航点击
 * @param {string} path - 目标路径
 * @param {Event} event - 点击事件
 */
const handleAuthClick = (path, event) => {
  event.preventDefault()

  if (userStore.isLoggedIn) {
    // 已登录：直接跳转
    navigateTo(path)
  } else {
    // 未登录：弹出登录弹窗，传入目标路径
    userStore.openLoginModal(path)
  }
}
</script>

